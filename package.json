{
  "name": "granola-agent",
  "version": "1.0.0",
  "description": "Granola meeting notes agent — query your meetings via iMessage, built on Linq Blue and Claude with Granola MCP",
  "main": "dist/index.js",
  "author": "George McCain",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/linq-team/granola-agent.git"
  },
  "keywords": [
    "granola",
    "meeting-notes",
    "linq",
    "linq-blue",
    "imessage",
    "claude",
    "anthropic",
    "mcp",
    "ai",
    "agent",
    "typescript"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "auth": "tsx src/granola/auth.ts",
    "test:granola": "tsx src/test-granola.ts",
    "chat": "tsx src/cli.ts",
    "build:lambda": "node esbuild.config.mjs",
    "build:layer": "bash scripts/build-layer.sh",
    "build:all": "npm run build:lambda && npm run build:layer",
    "deploy": "npm run build:all && cd infra && sam deploy",
    "deploy:guided": "npm run build:all && cd infra && sam deploy --guided"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-dynamodb": "^3.971.0",
    "@aws-sdk/client-sqs": "^3.971.0",
    "@aws-sdk/lib-dynamodb": "^3.971.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
