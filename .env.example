# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-xxx
# Optional model override (default claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=

# Linq Blue API
LINQ_API_TOKEN=your_linq_bearer_token
LINQ_API_BASE_URL=https://api.linqapp.com/api/partner/v3

# Public origin of THIS service (Render sets RENDER_EXTERNAL_URL; otherwise set BASE_URL)
# BASE_URL=https://your-assistant.onrender.com

# Shared secret with linq-imessage-assistant (Bearer token on ASSISTANT_WEBHOOK_URL calls)
# ASSISTANT_WEBHOOK_SECRET=

# Server
PORT=3000
LISTEN_HOST=0.0.0.0

# Linq Blue phone numbers this bot runs on (comma-separated, supports multiple)
LINQ_AGENT_BOT_NUMBERS=+14155551234

# Sender phone numbers to ignore (comma-separated)
IGNORED_SENDERS=

# Only respond to these sender numbers (comma-separated) - useful for local dev
ALLOWED_SENDERS=

# DynamoDB table name for conversation storage
DYNAMODB_TABLE_NAME=granola-agent

# Granola MCP
# OAuth token from Granola MCP auth flow (https://mcp.granola.ai/mcp)
# Run `npm run auth` to authenticate via browser and store the token
GRANOLA_MCP_URL=https://mcp.granola.ai/mcp

# Production: 64 hex chars (openssl rand -hex 32). Required for stable Granola token encryption at rest.
# CREDENTIAL_ENCRYPTION_KEY=

# --- Optional: Pipedrive deal tools (Claude) ---
# PIPEDRIVE_API_TOKEN=
# PIPEDRIVE_COMPANY_DOMAIN=

# --- Optional: Slack Web API tools (Claude) ---
# SLACK_BOT_TOKEN=xoxb-...
